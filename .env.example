# LLM provider: deepseek | qwen
LLM_PROVIDER=deepseek

# --- DeepSeek (used when LLM_PROVIDER=deepseek) ---
# Get API key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Alibaba Cloud Qwen DashScope (used when LLM_PROVIDER=qwen) ---
# Get API key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- Shared LLM settings ---
LLM_ENABLED=true
LLM_TIMEOUT_S=30
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
CLARIFICATION_CONFIDENCE_THRESHOLD=0.72
